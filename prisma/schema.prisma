generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  name     String
  role     String @default("admin")
}

model Property {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  type         String
  price        Float
  landArea     Float
  buildingArea Float
  bedrooms     Int
  bathrooms    Int
  carport      Int
  electricity  Int
  waterSupply  String
  description  String
  features     String
  images       String
  floorPlan    String?
  status       String   @default("available")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Facility {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  avatar    String
  review    String
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQItem {
  id       String   @id @default(cuid())
  question String
  answer   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model BookingInquiry {
  id            String   @id @default(cuid())
  fullName      String
  phone         String
  email         String
  preferredType String
  budget        Float
  surveyDate    String
  notes         String?
  createdAt     DateTime @default(now())
}

model NearbyPlace {
  id         String   @id @default(cuid())
  name       String
  category   String
  distance   String
  travelTime String
  icon       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
